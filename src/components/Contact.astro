---
---

<section class="section contact-section" id="contact">
  <div class="starwars-bg"></div>
  <div class="sw-ship cr90">
    <svg viewBox="0 0 180 60" fill="none">
      <rect x="20" y="15" width="140" height="30" rx="3" fill="#8a8a8a" stroke="#aaa" stroke-width="1.5"/>
      <rect x="30" y="10" width="100" height="40" rx="2" fill="#999" stroke="#bbb" stroke-width="1"/>
      <rect x="40" y="5" width="60" height="50" rx="2" fill="#888" stroke="#aaa" stroke-width="1"/>
      <rect x="10" y="20" width="15" height="20" rx="1" fill="#777" stroke="#999" stroke-width="0.5"/>
      <rect x="155" y="20" width="15" height="20" rx="1" fill="#777" stroke="#999" stroke-width="0.5"/>
      <rect x="45" y="15" width="50" height="30" rx="1" fill="#7a7a7a" stroke="#999" stroke-width="0.5"/>
      <rect x="50" y="20" width="40" height="20" rx="1" fill="#6a6a6a" stroke="#888" stroke-width="0.5"/>
      <circle cx="70" cy="30" r="4" fill="#555" stroke="#777" stroke-width="0.5"/>
      <circle cx="90" cy="30" r="3" fill="#555" stroke="#777" stroke-width="0.5"/>
      <circle cx="55" cy="30" r="2" fill="#555"/>
      <rect x="65" y="8" width="10" height="3" fill="#aaa"/>
      <rect x="85" y="8" width="10" height="3" fill="#aaa"/>
      <rect x="65" y="49" width="10" height="3" fill="#aaa"/>
      <rect x="85" y="49" width="10" height="3" fill="#aaa"/>
      <rect x="35" y="25" width="5" height="10" fill="#777"/>
      <rect x="120" y="25" width="5" height="10" fill="#777"/>
      <rect x="30" y="12" width="8" height="6" fill="#aaa" stroke="#ccc" stroke-width="0.5"/>
      <rect x="120" y="12" width="8" height="6" fill="#aaa" stroke="#ccc" stroke-width="0.5"/>
    </svg>
  </div>
  <div class="contact-inner">
      <h2 class="section-title" data-animate>Get in Touch</h2>
      <p class="section-subtitle" data-animate="fade">Have a question or want to work together? Reach out anytime.</p>

      <div class="contact-card" data-animate="scale">
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message" class="form-label">Message</label>
            <textarea id="message" name="message" class="form-input form-textarea" placeholder="Write your message..." rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>

        <div class="contact-info">
          <h3 class="info-title">Contact Info</h3>
          <div class="info-details">
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 4L12 13 2 4" />
              </svg>
              <a href="mailto:carldecastro989@gmail.com" class="detail-text">carldecastro989@gmail.com</a>
            </div>
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
              <a href="https://github.com/Agonnie2326uwu" target="_blank" rel="noopener noreferrer" class="detail-text">github.com/Agonnie2326uwu</a>
            </div>
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              <a href="https://facebook.com/Cannie2331" target="_blank" rel="noopener noreferrer" class="detail-text">facebook.com/Cannie2331</a>
            </div>
          </div>
        </div>
      </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
  }

  .contact-card {
    display: flex;
    gap: 40px;
    padding: 40px;
  }

  .contact-form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: flex;
    gap: 20px;
  }

  .form-row .form-group {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    font-family: var(--font-heading);
    letter-spacing: 0.5px;
  }

  .form-input {
    padding: 14px 18px;
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: rgba(6, 10, 26, 0.5);
    color: var(--color-text);
    transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(6, 10, 26, 0.7);
    box-shadow: 0 0 0 3px rgba(124, 109, 240, 0.1);
  }

  .form-input::placeholder {
    color: var(--color-text-light);
    opacity: 0.4;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-info {
    flex-shrink: 0;
    width: 240px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    padding-left: 40px;
    border-left: 1px solid var(--color-card-border);
  }

  .info-title {
    font-size: 1.1rem;
    margin-bottom: 4px;
    color: #fff;
  }

  .info-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .detail-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .detail-text {
    font-size: 0.85rem;
    color: var(--color-text-light);
    word-break: break-all;
  }

  .detail-text:hover {
    color: var(--color-primary);
  }

  @media (max-width: 700px) {
    .contact-card {
      flex-direction: column;
      gap: 28px;
      padding: 28px 20px;
    }

    .form-row {
      flex-direction: column;
      gap: 16px;
    }

    .contact-info {
      width: 100%;
      padding-left: 0;
      padding-top: 20px;
      border-left: none;
      border-top: 1px solid var(--color-card-border);
    }
  }
</style>
