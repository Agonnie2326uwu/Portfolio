---
---

<section class="section contact-section" id="contact">
  <div class="campfire-scene">
    <div class="campfire">
      <div class="campfire-glow"></div>
      <div class="fire-log fire-log-1"></div>
      <div class="fire-log fire-log-2"></div>
      <div class="fire-log fire-log-3"></div>
      <div class="fire-flame fire-flame-3"></div>
      <div class="fire-flame fire-flame-2"></div>
      <div class="fire-flame"></div>
      <div class="fire-spark fire-spark-1"></div>
      <div class="fire-spark fire-spark-2"></div>
      <div class="fire-spark fire-spark-3"></div>
    </div>
    <div class="cooking-stick cooking-stick-1"></div>
    <div class="cooking-stick cooking-stick-2"></div>
    <div class="mushroom mushroom-1"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-2"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-3"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-4"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="camper camper-1">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-2">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-3">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-4">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
  </div>
  <div class="night-overlay"></div>
  <div class="planet planet-saturn" style="top:5%;left:3%;transform:scale(0.6);"></div>
  <div class="planet planet-small" style="bottom:20%;right:4%;"></div>
  <div class="particle" style="bottom:15%;left:12%;--dur:16s;--delay:3s;--drift:22px;"></div>
  <div class="particle" style="bottom:40%;left:70%;--dur:20s;--delay:1s;--drift:-16px;--opacity:0.25;"></div>
  <div class="particle" style="bottom:60%;left:40%;--dur:18s;--delay:5s;--drift:14px;"></div>
  <div class="particle" style="bottom:25%;left:85%;--dur:22s;--delay:8s;--drift:-8px;--opacity:0.3;"></div>
  <div class="contact-inner night-inner">
      <h2 class="section-title" data-animate>Get in Touch</h2>
      <p class="section-subtitle" data-animate="fade">Have a question or want to work together? Reach out anytime.</p>

      <div class="contact-card card" data-animate="scale">
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-group">
            <label for="message" class="form-label">Message</label>
            <textarea id="message" name="message" class="form-input form-textarea" placeholder="Write your message..." rows="5" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>

        <div class="contact-info">
          <h3 class="info-title">Contact Info</h3>
          <div class="info-details">
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="M22 4L12 13 2 4" />
              </svg>
              <a href="mailto:carldecastro989@gmail.com" class="detail-text">carldecastro989@gmail.com</a>
            </div>
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
              </svg>
              <a href="https://github.com/Agonnie2326uwu" target="_blank" rel="noopener noreferrer" class="detail-text">github.com/Agonnie2326uwu</a>
            </div>
            <div class="detail">
              <svg class="detail-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
              </svg>
              <a href="https://facebook.com/Cannie2331" target="_blank" rel="noopener noreferrer" class="detail-text">facebook.com/Cannie2331</a>
            </div>
          </div>
        </div>
      </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
  }

  .contact-card {
    display: flex;
    gap: 40px;
    padding: 40px;
  }

  .contact-form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: flex;
    gap: 20px;
  }

  .form-row .form-group {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    font-family: var(--font-heading);
    letter-spacing: 0.5px;
  }

  .form-input {
    padding: 14px 18px;
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: rgba(6, 10, 26, 0.5);
    color: var(--color-text);
    transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(6, 10, 26, 0.7);
    box-shadow: 0 0 0 3px rgba(124, 109, 240, 0.1);
  }

  .form-input::placeholder {
    color: var(--color-text-light);
    opacity: 0.4;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-info {
    flex-shrink: 0;
    width: 240px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    padding-left: 40px;
    border-left: 1px solid var(--color-card-border);
  }

  .info-title {
    font-size: 1.1rem;
    margin-bottom: 4px;
    color: #fff;
  }

  .info-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .detail-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .detail-text {
    font-size: 0.85rem;
    color: var(--color-text-light);
    word-break: break-all;
  }

  .detail-text:hover {
    color: var(--color-primary);
  }

  @media (max-width: 700px) {
    .contact-card {
      flex-direction: column;
      gap: 28px;
      padding: 28px 20px;
    }

    .form-row {
      flex-direction: column;
      gap: 16px;
    }

    .contact-info {
      width: 100%;
      padding-left: 0;
      padding-top: 20px;
      border-left: none;
      border-top: 1px solid var(--color-card-border);
    }
  }
</style>
