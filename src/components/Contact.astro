<section class="section contact-section" id="contact">
  <div class="night-bg"></div>
  <div class="moon-big moon-mid-right"></div>
  <div class="campfire-scene">
    <div class="campfire">
      <div class="campfire-glow"></div>
      <div class="fire-log fire-log-1"></div>
      <div class="fire-log fire-log-2"></div>
      <div class="fire-log fire-log-3"></div>
      <div class="fire-flame fire-flame-3"></div>
      <div class="fire-flame fire-flame-2"></div>
      <div class="fire-flame"></div>
      <div class="fire-spark fire-spark-1"></div>
      <div class="fire-spark fire-spark-2"></div>
      <div class="fire-spark fire-spark-3"></div>
    </div>
    <div class="cooking-stick cooking-stick-1"></div>
    <div class="cooking-stick cooking-stick-2"></div>
    <div class="mushroom mushroom-1"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-2"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-3"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="mushroom mushroom-4"><div class="mushroom-cap"></div><div class="mushroom-stem"></div></div>
    <div class="camper camper-1">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-2">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-3">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
    <div class="camper camper-4">
      <div class="camper-head"></div>
      <div class="camper-body"></div>
      <div class="camper-arm"></div>
    </div>
  </div>
  <div class="night-overlay"></div>
  <div class="star star-1"></div>
  <div class="star star-3"></div>
  <div class="star star-5"></div>
  <div class="star star-6"></div>
  <div class="star star-8"></div>
  <div class="star star-10"></div>
  <div class="contact-inner night-inner">
    <h2 class="section-title">Get in Touch</h2>
    <p class="section-subtitle">Have a question or want to work together? Reach out anytime.</p>

    <div class="contact-card card">
      <form class="contact-form" netlify>
        <div class="form-row">
          <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
          </div>
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea id="message" name="message" class="form-input form-textarea" placeholder="Write your message..." rows="5" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>

      <div class="contact-info">
        <h3 class="info-title">Contact Info</h3>
        <div class="info-details">
          <div class="detail">
            <span class="detail-icon">📧</span>
            <a href="mailto:carldecastro989@gmail.com" class="detail-text">carldecastro989@gmail.com</a>
          </div>
          <div class="detail">
            <span class="detail-icon">🐙</span>
            <a href="https://github.com/Agonnie2326uwu" target="_blank" rel="noopener noreferrer" class="detail-text">github.com/Agonnie2326uwu</a>
          </div>
          <div class="detail">
            <span class="detail-icon">📘</span>
            <a href="https://facebook.com/Cannie2331" target="_blank" rel="noopener noreferrer" class="detail-text">facebook.com/Cannie2331</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
  }

  .contact-card {
    display: flex;
    gap: 40px;
    padding: 40px;
  }

  .contact-form {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: flex;
    gap: 20px;
  }

  .form-row .form-group {
    flex: 1;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    font-family: var(--font-heading);
    letter-spacing: 0.5px;
  }

  .form-input {
    padding: 12px 16px;
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.95rem;
    background: rgba(6, 10, 26, 0.5);
    color: var(--color-text);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    background: rgba(6, 10, 26, 0.7);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-info {
    flex-shrink: 0;
    width: 240px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    padding-left: 40px;
    border-left: 1px solid var(--color-card-border);
  }

  .info-title {
    font-size: 1.1rem;
    margin-bottom: 4px;
    color: #fff;
  }

  .info-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .detail-icon {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .detail-text {
    font-size: 0.85rem;
    color: var(--color-text-light);
    word-break: break-all;
  }

  .detail-text:hover {
    color: var(--color-primary);
  }

  @media (max-width: 700px) {
    .contact-card {
      flex-direction: column;
      gap: 28px;
      padding: 28px 20px;
    }

    .form-row {
      flex-direction: column;
      gap: 16px;
    }

    .contact-info {
      width: 100%;
      padding-left: 0;
      padding-top: 20px;
      border-left: none;
      border-top: 1px solid var(--color-card-border);
    }
  }
</style>
