---
const skills = [
  {
    name: 'Python',
    level: 'Advanced',
    projects: 6,
    desc: 'Scripting, automation, data processing, and clean, readable code for diverse use cases.',
  },
  {
    name: 'C++',
    level: 'Intermediate',
    projects: 5,
    desc: 'Systems programming, memory management, and performant algorithm implementation.',
  },
  {
    name: 'C#',
    level: 'Intermediate',
    projects: 4,
    desc: 'Desktop applications and game development using the .NET framework.',
  },
];
---

<section class="section skills-section" id="skills">
  <div class="starwars-bg"></div>
  <div class="sw-ship xwing">
    <svg viewBox="0 0 120 80" fill="none">
      <rect x="50" y="10" width="20" height="60" rx="2" fill="#c0c0c0" stroke="#888" stroke-width="1"/>
      <rect x="30" y="20" width="60" height="40" rx="2" fill="#aaa" stroke="#888" stroke-width="1"/>
      <rect x="40" y="15" width="40" height="50" rx="1" fill="#999" stroke="#777" stroke-width="0.5"/>
      <rect x="55" y="5" width="10" height="70" fill="#bbb" stroke="#999" stroke-width="0.5"/>
      <rect x="20" y="25" width="10" height="30" fill="#ccc" stroke="#aaa" stroke-width="0.5"/>
      <rect x="90" y="25" width="10" height="30" fill="#ccc" stroke="#aaa" stroke-width="0.5"/>
      <rect x="45" y="30" width="30" height="20" fill="#888" stroke="#666" stroke-width="0.5"/>
      <rect x="50" y="8" width="20" height="4" rx="1" fill="#aaa" stroke="#888" stroke-width="0.5"/>
      <rect x="50" y="68" width="20" height="4" rx="1" fill="#aaa" stroke="#888" stroke-width="0.5"/>
      <circle cx="60" cy="40" r="4" fill="#444" stroke="#666" stroke-width="0.5"/>
      <rect x="42" y="22" width="6" height="4" fill="#666"/>
      <rect x="72" y="22" width="6" height="4" fill="#666"/>
      <rect x="42" y="54" width="6" height="4" fill="#666"/>
      <rect x="72" y="54" width="6" height="4" fill="#666"/>
    </svg>
  </div>
  <div class="skills-inner">
      <h2 class="section-title" data-animate>Skills &amp; Technologies</h2>
      <p class="section-subtitle" data-animate="fade">Programming languages and tools I've worked with.</p>

      <div class="skills-grid">
        {skills.map((skill, i) => (
          <div class="skill-card float-anim" data-animate="scale" style={"transition-delay:" + (i * 0.1) + "s;animation-delay:" + (i * 0.5) + "s"}>
            <div class="skill-header">
              <h3 class="skill-name">{skill.name}</h3>
              <span class="skill-level">{skill.level}</span>
            </div>
            <p class="skill-desc">{skill.desc}</p>
          </div>
        ))}
      </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    overflow: hidden;
  }

  .skills-inner {
    position: relative;
    z-index: 2;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .skill-card {
    padding: 24px;
  }

  .skill-header {
    margin-bottom: 14px;
  }

  .skill-name {
    font-size: 1.15rem;
    margin-bottom: 2px;
    color: #fff;
  }

  .skill-level {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .skill-desc {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .skill-footer {
    padding-top: 12px;
    border-top: 1px solid var(--color-card-border);
  }

  .skill-stat {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
</style>
