---
const skills = [
  {
    name: 'Python',
    level: 'Advanced',
    points: ['Scripting & automation', 'Data processing', 'Clean, readable code'],
  },
  {
    name: 'Java',
    level: 'Intermediate',
    points: ['OOP & data structures', 'Android development', 'Desktop applications'],
  },
  {
    name: 'C++',
    level: 'Intermediate',
    points: ['Systems programming', 'Memory management', 'Performant algorithms'],
  },
  {
    name: 'C#',
    level: 'Intermediate',
    points: ['Desktop applications', '.NET framework', 'Game development'],
  },
];
---

<section class="section skills-section" id="skills">
  <div class="skills-inner">
      <h2 class="section-title">Skills &amp; Technologies</h2>
      <p class="section-subtitle">Programming languages and tools I've worked with.</p>

      <div class="skills-grid">
        {skills.map((skill, i) => (
          <div class="skill-card">
            <div class="skill-header">
              <h3 class="skill-name">{skill.name}</h3>
              <span class="skill-level">{skill.level}</span>
            </div>
            <ul class="skill-points">
              {skill.points.map((point) => (
                <li class="skill-point">{point}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    overflow: hidden;
  }

  .skills-inner {
    position: relative;
    z-index: 2;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .skill-card {
    padding: 40px;
    border: var(--pixel-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.85);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .skill-card:hover {
    border-color: var(--color-text);
    transform: translateY(-4px);
  }

  .skill-header {
    margin-bottom: 14px;
  }

  .skill-name {
    font-size: 1.15rem;
    margin-bottom: 2px;
    color: var(--color-text);
  }

  .skill-level {
    font-size: 0.8rem;
    color: var(--color-text-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .skill-points {
    list-style: disc;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .skill-point {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .skill-footer {
    padding-top: 12px;
    border-top: 1px solid var(--color-card-border);
  }

  .skill-stat {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
</style>
