---
const skills = [
  {
    name: 'Java',
    level: 'Advanced',
    projects: 8,
    desc: 'Object-oriented programming, data structures, and cross-platform application development.',
    svg: '<svg viewBox="0 0 40 40" width="36" height="36"><rect x="4" y="8" width="32" height="24" rx="3" fill="none" stroke="#7c6df0" stroke-width="2.5"/><rect x="8" y="12" width="24" height="6" rx="1.5" fill="#7c6df0" opacity="0.3"/><rect x="8" y="20" width="16" height="5" rx="1.5" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.6"/><rect x="8" y="27" width="10" height="3" rx="1" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.4"/></svg>',
  },
  {
    name: 'Python',
    level: 'Advanced',
    projects: 6,
    desc: 'Scripting, automation, data processing, and clean, readable code for diverse use cases.',
    svg: '<svg viewBox="0 0 40 40" width="36" height="36"><path d="M20 6 C12 6 10 10 10 14 L10 18 C10 22 12 24 20 24 L28 24 C32 24 34 26 34 30 L34 34 C34 38 30 40 22 40 C14 40 10 38 10 34" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linecap="round"/><circle cx="16" cy="14" r="2" fill="#4a9eff"/><circle cx="24" cy="32" r="2" fill="#f0c040"/><path d="M20 34 C28 34 30 32 30 28 L30 24 C30 20 28 18 20 18 L12 18" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linecap="round"/></svg>',
  },
  {
    name: 'C++',
    level: 'Intermediate',
    projects: 5,
    desc: 'Systems programming, memory management, and performant algorithm implementation.',
    svg: '<svg viewBox="0 0 40 40" width="36" height="36"><circle cx="20" cy="20" r="14" fill="none" stroke="#7c6df0" stroke-width="2.5"/><text x="20" y="25" text-anchor="middle" fill="#4a9eff" font-size="15" font-weight="bold" font-family="monospace">++</text><line x1="6" y1="20" x2="10" y2="20" stroke="#7c6df0" stroke-width="2" stroke-linecap="round"/><line x1="30" y1="20" x2="34" y2="20" stroke="#7c6df0" stroke-width="2" stroke-linecap="round"/></svg>',
  },
  {
    name: 'C#',
    level: 'Intermediate',
    projects: 4,
    desc: 'Desktop applications and game development using the .NET framework.',
    svg: '<svg viewBox="0 0 40 40" width="36" height="36"><rect x="6" y="6" width="28" height="28" rx="4" fill="none" stroke="#7c6df0" stroke-width="2.5"/><text x="20" y="26" text-anchor="middle" fill="#4a9eff" font-size="16" font-weight="bold" font-family="monospace">#</text><line x1="6" y1="14" x2="10" y2="14" stroke="#7c6df0" stroke-width="2" stroke-linecap="round"/><line x1="30" y1="26" x2="34" y2="26" stroke="#7c6df0" stroke-width="2" stroke-linecap="round"/></svg>',
  },
];
---

<section class="section skills-section" id="skills">
  <div class="cosmic-bg" data-parallax="0.15"></div>
  <div class="stars-dense" data-parallax="0.1"></div>
  <div class="cosmic-overlay"></div>
  <div class="moon-big moon-top-right"></div>
  <div class="planet planet-nebula" style="top:45%;left:6%;transform:scale(0.9);"></div>
  <div class="planet planet-small" style="bottom:20%;right:5%;"></div>
  <div class="constellation constellation-3">
    <svg viewBox="0 0 110 75">
      <circle class="constellation-dot" cx="20" cy="60" r="2" />
      <circle class="constellation-dot" cx="35" cy="25" r="2.5" />
      <circle class="constellation-dot" cx="55" cy="40" r="2" />
      <circle class="constellation-dot" cx="80" cy="15" r="2.5" />
      <circle class="constellation-dot" cx="95" cy="50" r="2" />
      <line class="constellation-line" x1="20" y1="60" x2="35" y2="25" />
      <line class="constellation-line" x1="35" y1="25" x2="55" y2="40" />
      <line class="constellation-line" x1="55" y1="40" x2="80" y2="15" />
      <line class="constellation-line constellation-line-2" x1="80" y1="15" x2="95" y2="50" />
    </svg>
  </div>
  <div class="particle" style="bottom:15%;left:5%;--dur:19s;--delay:1s;--drift:20px;"></div>
  <div class="particle" style="bottom:35%;left:45%;--dur:21s;--delay:4s;--drift:-10px;--opacity:0.3;"></div>
  <div class="particle" style="bottom:55%;left:80%;--dur:17s;--delay:7s;--drift:15px;"></div>
  <div class="particle" style="bottom:25%;left:20%;--dur:23s;--delay:2s;--drift:-25px;--opacity:0.25;"></div>
  <div class="shooting-star" style="top:20%;left:40%;animation:shootStar 14s ease-in-out 5s infinite;width:2px;height:2px;"></div>
  <div class="shooting-star" style="top:8%;right:15%;animation:shootStar 18s ease-in-out 10s infinite;"></div>
  <div class="star star-2"></div>
  <div class="star star-4"></div>
  <div class="star star-5"></div>
  <div class="star star-8"></div>
  <div class="star star-10"></div>
  <div class="star star-1"></div>
  <div class="star star-9"></div>
  <div class="skills-inner cosmic-inner">
    <h2 class="section-title" data-animate>Skills &amp; Technologies</h2>
    <p class="section-subtitle" data-animate="fade">Programming languages and tools I've worked with.</p>

    <div class="skills-grid">
      {skills.map((skill, i) => (
        <div class="skill-card card" data-animate="scale" style={"transition-delay:" + (i * 0.1) + "s"}>
          <div class="skill-header">
            <span class="skill-icon" set:html={skill.svg}></span>
            <div>
              <h3 class="skill-name">{skill.name}</h3>
              <span class="skill-level">{skill.level}</span>
            </div>
          </div>
          <p class="skill-desc">{skill.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    overflow: hidden;
  }

  .skills-inner {
    position: relative;
    z-index: 2;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .skill-card {
    padding: 24px;
  }

  .skill-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }

  .skill-icon {
    font-size: 2.2rem;
    flex-shrink: 0;
  }

  .skill-name {
    font-size: 1.15rem;
    margin-bottom: 2px;
    color: #fff;
  }

  .skill-level {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .skill-desc {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .skill-footer {
    padding-top: 12px;
    border-top: 1px solid var(--color-card-border);
  }

  .skill-stat {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
</style>
