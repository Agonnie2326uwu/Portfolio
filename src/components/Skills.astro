---
const skills = [
  {
    name: 'Python',
    level: 'Advanced',
    projects: 6,
    desc: 'Scripting, automation, data processing, and clean, readable code for diverse use cases.',
  },
  {
    name: 'C++',
    level: 'Intermediate',
    projects: 5,
    desc: 'Systems programming, memory management, and performant algorithm implementation.',
  },
  {
    name: 'C#',
    level: 'Intermediate',
    projects: 4,
    desc: 'Desktop applications and game development using the .NET framework.',
  },
];
---

<section class="section skills-section" id="skills">
  <div class="cosmic-bg" data-parallax="0.15"></div>
  <div class="stars-dense" data-parallax="0.1"></div>
  <div class="cosmic-overlay"></div>
  <div class="moon-big moon-top-right"></div>
  <div class="planet planet-nebula" style="top:45%;left:6%;transform:scale(0.9);"></div>
  <div class="planet planet-small" style="bottom:20%;right:5%;"></div>
  <div class="constellation constellation-3">
    <svg viewBox="0 0 110 75">
      <circle class="constellation-dot" cx="20" cy="60" r="2" />
      <circle class="constellation-dot" cx="35" cy="25" r="2.5" />
      <circle class="constellation-dot" cx="55" cy="40" r="2" />
      <circle class="constellation-dot" cx="80" cy="15" r="2.5" />
      <circle class="constellation-dot" cx="95" cy="50" r="2" />
      <line class="constellation-line" x1="20" y1="60" x2="35" y2="25" />
      <line class="constellation-line" x1="35" y1="25" x2="55" y2="40" />
      <line class="constellation-line" x1="55" y1="40" x2="80" y2="15" />
      <line class="constellation-line constellation-line-2" x1="80" y1="15" x2="95" y2="50" />
    </svg>
  </div>
  <div class="particle" style="bottom:15%;left:5%;--dur:19s;--delay:1s;--drift:20px;"></div>
  <div class="particle" style="bottom:35%;left:45%;--dur:21s;--delay:4s;--drift:-10px;--opacity:0.3;"></div>
  <div class="particle" style="bottom:55%;left:80%;--dur:17s;--delay:7s;--drift:15px;"></div>
  <div class="particle" style="bottom:25%;left:20%;--dur:23s;--delay:2s;--drift:-25px;--opacity:0.25;"></div>
  <div class="shooting-star" style="top:20%;left:40%;animation:shootStar 14s ease-in-out 5s infinite;width:2px;height:2px;"></div>
  <div class="shooting-star" style="top:8%;right:15%;animation:shootStar 18s ease-in-out 10s infinite;"></div>
  <div class="star star-2"></div>
  <div class="star star-4"></div>
  <div class="star star-5"></div>
  <div class="star star-8"></div>
  <div class="star star-10"></div>
  <div class="star star-1"></div>
  <div class="star star-9"></div>
  <div class="skills-inner cosmic-inner">
    <div class="section-card">
      <h2 class="section-title" data-animate>Skills &amp; Technologies</h2>
      <p class="section-subtitle" data-animate="fade">Programming languages and tools I've worked with.</p>

      <div class="skills-grid">
        {skills.map((skill, i) => (
          <div class="skill-card card float-anim" data-animate="scale" style={"transition-delay:" + (i * 0.1) + "s;animation-delay:" + (i * 0.5) + "s"}>
            <div class="skill-header">
              <h3 class="skill-name">{skill.name}</h3>
              <span class="skill-level">{skill.level}</span>
            </div>
            <p class="skill-desc">{skill.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    position: relative;
    overflow: hidden;
  }

  .skills-inner {
    position: relative;
    z-index: 2;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .skill-card {
    padding: 24px;
  }

  .skill-header {
    margin-bottom: 14px;
  }

  .skill-name {
    font-size: 1.15rem;
    margin-bottom: 2px;
    color: #fff;
  }

  .skill-level {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .skill-desc {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .skill-footer {
    padding-top: 12px;
    border-top: 1px solid var(--color-card-border);
  }

  .skill-stat {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }
</style>
