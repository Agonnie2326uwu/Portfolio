---
---

<section class="section goals-section" id="goals">
  <div class="night-bg" data-parallax="0.15"></div>
  <div class="moon-big moon-top-left"></div>
  <div class="mountains">
    <div class="mountain mountain-2"></div>
    <div class="mountain mountain-3"></div>
    <div class="mountain mountain-5"></div>
  </div>
  <div class="trees">
    <div class="tree tree-1"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-2"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-4"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-6"><div class="tree-body"></div><div class="tree-trunk"></div></div>
  </div>
  <div class="night-overlay"></div>
  <div class="planet planet-nebula" style="top:10%;right:4%;transform:scale(0.7);"></div>
  <div class="planet planet-small" style="bottom:25%;left:5%;"></div>
  <div class="constellation constellation-1" style="top:auto;bottom:15%;left:3%;width:90px;height:60px;">
    <svg viewBox="0 0 90 60">
      <circle class="constellation-dot" cx="12" cy="40" r="2.5" />
      <circle class="constellation-dot" cx="28" cy="10" r="2" />
      <circle class="constellation-dot" cx="48" cy="25" r="2.5" />
      <circle class="constellation-dot" cx="68" cy="8" r="2" />
      <circle class="constellation-dot" cx="82" cy="45" r="2" />
      <line class="constellation-line" x1="12" y1="40" x2="28" y2="10" />
      <line class="constellation-line" x1="28" y1="10" x2="48" y2="25" />
      <line class="constellation-line" x1="48" y1="25" x2="68" y2="8" />
      <line class="constellation-line constellation-line-2" x1="68" y1="8" x2="82" y2="45" />
    </svg>
  </div>
  <div class="particle" style="bottom:20%;left:8%;--dur:17s;--delay:2s;--drift:18px;"></div>
  <div class="particle" style="bottom:45%;left:50%;--dur:21s;--delay:6s;--drift:-14px;--opacity:0.3;"></div>
  <div class="particle" style="bottom:65%;left:25%;--dur:19s;--delay:1s;--drift:10px;"></div>
  <div class="shooting-star" style="top:10%;left:20%;animation:shootStar 13s ease-in-out 6s infinite;width:2px;height:2px;"></div>
  <div class="shooting-star" style="top:35%;right:5%;animation:shootStar 17s ease-in-out 11s infinite;"></div>
  <div class="star star-1"></div>
  <div class="star star-2"></div>
  <div class="star star-3"></div>
  <div class="star star-4"></div>
  <div class="star star-5"></div>
  <div class="star star-6"></div>
  <div class="star star-7"></div>
  <div class="star star-8"></div>
  <div class="star star-9"></div>
  <div class="star star-10"></div>
  <div class="goals-inner night-inner">
    <div class="section-card">
      <h2 class="section-title" data-animate>Goals &amp; Aspirations</h2>
      <p class="section-subtitle" data-animate="fade">What I'm working toward.</p>

      <div class="goals-grid">
        <div class="goal-card card float-anim" data-animate="scale" style="transition-delay:0.1s;animation-delay:0s;">
          <div class="icon-3d icon-dev">
            <div class="icon-face icon-front">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <rect x="10" y="14" width="44" height="36" rx="4" fill="none" stroke="#7c6df0" stroke-width="2.5"/>
                <rect x="14" y="18" width="36" height="10" rx="2" fill="#7c6df0" opacity="0.3"/>
                <rect x="14" y="31" width="22" height="8" rx="2" fill="none" stroke="#4a9eff" stroke-width="2" opacity="0.6"/>
                <rect x="14" y="42" width="14" height="5" rx="2" fill="none" stroke="#4a9eff" stroke-width="2" opacity="0.4"/>
                <line x1="40" y1="32" x2="50" y2="38" stroke="#f0c040" stroke-width="2" stroke-linecap="round"/>
                <line x1="40" y1="36" x2="50" y2="30" stroke="#f0c040" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="icon-face icon-back">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <circle cx="32" cy="32" r="20" fill="none" stroke="#7c6df0" stroke-width="2.5"/>
                <circle cx="32" cy="32" r="10" fill="none" stroke="#4a9eff" stroke-width="2"/>
                <circle cx="32" cy="32" r="3" fill="#f0c040"/>
                <line x1="32" y1="12" x2="32" y2="22" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
                <line x1="32" y1="42" x2="32" y2="52" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
                <line x1="12" y1="32" x2="22" y2="32" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
                <line x1="42" y1="32" x2="52" y2="32" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="icon-face icon-right">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <path d="M16 44 L32 14 L48 44 Z" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linejoin="round"/>
                <line x1="24" y1="34" x2="40" y2="34" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
                <line x1="28" y1="28" x2="36" y2="28" stroke="#4a9eff" stroke-width="2" stroke-linecap="round"/>
                <line x1="32" y1="14" x2="32" y2="44" stroke="#f0c040" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              </svg>
            </div>
            <div class="icon-face icon-left">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <rect x="12" y="18" width="40" height="28" rx="3" fill="none" stroke="#7c6df0" stroke-width="2.5"/>
                <text x="32" y="37" text-anchor="middle" fill="#4a9eff" font-size="18" font-weight="bold" font-family="monospace">&lt;/&gt;</text>
              </svg>
            </div>
          </div>
          <h3 class="goal-title">Full-Stack Developer</h3>
          <p>
            My goal is to become a successful Full-Stack Developer by continuously improving my skills,
            gaining real-world experience, and building applications that solve meaningful problems.
          </p>
        </div>

        <div class="goal-card card float-anim float-anim-delay-1" data-animate="scale" style="transition-delay:0.2s;animation-delay:0.5s;">
          <div class="icon-3d icon-animal">
            <div class="icon-face icon-front">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <path d="M12 34 L32 14 L52 34" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linejoin="round"/>
                <rect x="20" y="34" width="24" height="22" rx="2" fill="none" stroke="#7c6df0" stroke-width="2"/>
                <rect x="26" y="40" width="12" height="16" rx="1" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.7"/>
                <line x1="32" y1="14" x2="32" y2="20" stroke="#f0c040" stroke-width="2" stroke-linecap="round"/>
                <circle cx="32" cy="18" r="2" fill="#f0c040"/>
              </svg>
            </div>
            <div class="icon-face icon-back">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <rect x="14" y="18" width="36" height="38" rx="3" fill="none" stroke="#7c6df0" stroke-width="2.5"/>
                <polygon points="8,22 32,6 56,22" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linejoin="round"/>
                <rect x="24" y="34" width="16" height="22" rx="2" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.7"/>
                <rect x="34" y="24" width="10" height="8" rx="1.5" fill="none" stroke="#f0c040" stroke-width="1.5" opacity="0.6"/>
              </svg>
            </div>
            <div class="icon-face icon-right">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <path d="M14 34 L32 16 L50 34" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linejoin="round"/>
                <rect x="18" y="34" width="28" height="22" rx="2" fill="none" stroke="#7c6df0" stroke-width="2"/>
                <path d="M22 46 L32 36 L42 46" fill="none" stroke="#f0c040" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.8"/>
                <path d="M28 38 L32 34 L36 38" fill="none" stroke="#4a9eff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <line x1="32" y1="16" x2="32" y2="22" stroke="#f0c040" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="icon-face icon-left">
              <svg viewBox="0 0 64 64" width="48" height="48">
                <rect x="10" y="30" width="44" height="26" rx="3" fill="none" stroke="#7c6df0" stroke-width="2.5"/>
                <polygon points="6,32 32,10 58,32" fill="none" stroke="#7c6df0" stroke-width="2.5" stroke-linejoin="round"/>
                <circle cx="32" cy="44" r="8" fill="none" stroke="#4a9eff" stroke-width="2"/>
                <path d="M28 44 L32 48 L36 44" fill="none" stroke="#f0c040" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="24" y="24" width="6" height="6" rx="1" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.5"/>
                <rect x="34" y="24" width="6" height="6" rx="1" fill="none" stroke="#4a9eff" stroke-width="1.5" opacity="0.5"/>
              </svg>
            </div>
          </div>
          <h3 class="goal-title">Animal Sanctuary</h3>
          <p>
            I hope to establish an animal sanctuary where abandoned, injured, and rescued animals can
            receive proper care, protection, and a safe place to live.
          </p>
        </div>
      </div>

      <div class="goal-combined card" data-animate="fade">
        <p>
          Combining my passion for technology with my love for animals is something I aspire to achieve
          in the future.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .goals-section {
    position: relative;
    overflow: hidden;
  }

  .goals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 24px;
  }

  .goal-card {
    text-align: center;
    padding: 36px 28px;
  }

  .goal-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .icon-3d {
    width: 88px;
    height: 88px;
    margin: 0 auto 20px;
    perspective: 400px;
    position: relative;
    transform-style: preserve-3d;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-dev {
    animation: rotateY3D 6s linear infinite;
  }

  .icon-animal {
    animation: rotateX3D 6s linear infinite;
  }

  .icon-face {
    position: absolute;
    width: 88px;
    height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }

  .icon-front {
    transform: translateZ(22px);
  }

  .icon-back {
    transform: rotateY(180deg) translateZ(22px);
  }

  .icon-right {
    transform: rotateY(90deg) translateZ(22px);
  }

  .icon-left {
    transform: rotateY(-90deg) translateZ(22px);
  }

  @keyframes rotateY3D {
    0% { transform: rotateY(0deg) rotateX(5deg); }
    100% { transform: rotateY(360deg) rotateX(5deg); }
  }

  @keyframes rotateX3D {
    0% { transform: rotateX(0deg) rotateY(15deg); }
    100% { transform: rotateX(360deg) rotateY(15deg); }
  }

  .goal-title {
    font-size: 1.3rem;
    margin-bottom: 14px;
    color: #fff;
  }

  .goal-card p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .goal-combined {
    text-align: center;
    padding: 32px;
    position: relative;
  }

  .goal-combined::before {
    content: '"';
    position: absolute;
    top: 8px;
    left: 20px;
    font-size: 3rem;
    color: var(--color-primary);
    opacity: 0.2;
    font-family: serif;
    line-height: 1;
  }

  .goal-combined::after {
    content: '"';
    position: absolute;
    bottom: 4px;
    right: 20px;
    font-size: 3rem;
    color: var(--color-primary);
    opacity: 0.2;
    font-family: serif;
    line-height: 1;
  }

  .goal-combined p {
    font-size: 1.05rem;
    line-height: 1.8;
    font-style: italic;
    color: var(--color-primary);
  }
</style>
