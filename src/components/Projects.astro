---
const projects = [
  {
    title: 'Hangarin',
    type: 'Web Application',
    desc: 'A full-featured web application built with modern technologies, demonstrating clean architecture and responsive design.',
    tags: ['React', 'Node.js', 'MongoDB'],
    repo: 'https://github.com/Agonnie2326uwu/Hangarin',
    image: '',
  },
  {
    title: 'Palawan Endemic',
    type: 'Wildlife & Conservation',
    desc: 'A digital guide showcasing the unique endemic species of Palawan, Philippines. Features species profiles, habitat maps, and conservation resources.',
    tags: ['HTML', 'CSS', 'JavaScript', 'GitHub Pages'],
    repo: 'https://github.com/Agonnie2326uwu/Palawan-Endemic',
    image: '',
  },
];
---

<section class="section projects-section" id="projects">
  <div class="night-bg" data-parallax="0.15"></div>
  <div class="moon-big moon-top-right"></div>
  <div class="mountains">
    <div class="mountain mountain-1"></div>
    <div class="mountain mountain-2"></div>
    <div class="mountain mountain-3"></div>
    <div class="mountain mountain-4"></div>
    <div class="mountain mountain-5"></div>
  </div>
  <div class="trees">
    <div class="tree tree-1"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-2"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-3"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-4"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-5"><div class="tree-body"></div><div class="tree-trunk"></div></div>
    <div class="tree tree-6"><div class="tree-body"></div><div class="tree-trunk"></div></div>
  </div>
  <div class="night-overlay"></div>
  <div class="planet planet-small" style="top:8%;left:12%;"></div>
  <div class="planet planet-nebula" style="top:50%;right:4%;transform:scale(0.6);"></div>
  <div class="constellation constellation-2" style="top:auto;bottom:20%;right:5%;width:100px;height:65px;">
    <svg viewBox="0 0 100 65">
      <circle class="constellation-dot" cx="15" cy="45" r="2" />
      <circle class="constellation-dot" cx="30" cy="12" r="2.5" />
      <circle class="constellation-dot" cx="50" cy="30" r="2" />
      <circle class="constellation-dot" cx="70" cy="8" r="2.5" />
      <circle class="constellation-dot" cx="88" cy="50" r="2" />
      <line class="constellation-line" x1="15" y1="45" x2="30" y2="12" />
      <line class="constellation-line" x1="30" y1="12" x2="50" y2="30" />
      <line class="constellation-line" x1="50" y1="30" x2="70" y2="8" />
      <line class="constellation-line constellation-line-2" x1="70" y1="8" x2="88" y2="50" />
    </svg>
  </div>
  <div class="particle" style="bottom:10%;left:15%;--dur:20s;--delay:0s;--drift:12px;"></div>
  <div class="particle" style="bottom:30%;left:60%;--dur:18s;--delay:5s;--drift:-18px;--opacity:0.25;"></div>
  <div class="particle" style="bottom:50%;left:35%;--dur:22s;--delay:2s;--drift:8px;"></div>
  <div class="particle" style="bottom:70%;left:80%;--dur:16s;--delay:7s;--drift:-12px;--opacity:0.3;"></div>
  <div class="shooting-star" style="top:12%;right:25%;animation:shootStar 15s ease-in-out 4s infinite;"></div>
  <div class="shooting-star" style="top:40%;left:8%;animation:shootStar 20s ease-in-out 9s infinite;width:2px;height:2px;"></div>
  <div class="star star-1"></div>
  <div class="star star-2"></div>
  <div class="star star-3"></div>
  <div class="star star-4"></div>
  <div class="star star-5"></div>
  <div class="star star-6"></div>
  <div class="star star-7"></div>
  <div class="star star-8"></div>
  <div class="star star-9"></div>
  <div class="star star-10"></div>
  <div class="projects-inner night-inner">
    <h2 class="section-title" data-animate>Projects</h2>
    <p class="section-subtitle" data-animate="fade">A selection of work I've built along my journey.</p>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <div class="project-card card" data-animate="scale" style={"transition-delay:" + (i * 0.15) + "s"}>
          {project.image && <div class="project-image"><img src={project.image} alt={project.title} /></div>}
          <div class="project-type">{project.type}</div>
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.desc}</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          {(project.repo || project.link) && (
            <div class="project-links">
              {project.repo && <a href={project.repo} target="_blank" rel="noopener noreferrer" class="btn-project">View on GitHub</a>}
              {project.link && <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-project btn-project-outline">Live Demo</a>}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section {
    position: relative;
    overflow: hidden;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
  }

  .project-image {
    width: calc(100% + 56px);
    margin: -28px -28px 20px;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    overflow: hidden;
    max-height: 180px;
  }

  .project-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .project-type {
    font-size: 0.78rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .project-title {
    font-size: 1.4rem;
    margin-bottom: 12px;
    color: #fff;
  }

  .project-desc {
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 0.75rem;
    padding: 4px 14px;
    border-radius: 20px;
    background: rgba(124, 109, 240, 0.15);
    color: var(--color-text);
    font-weight: 500;
  }

  .project-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-card-border);
  }

  .btn-project {
    display: inline-block;
    padding: 8px 20px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--color-primary);
    color: #fff;
    transition: all 0.3s ease;
    letter-spacing: 0.3px;
  }

  .btn-project:hover {
    background: var(--color-primary-dark);
    color: #fff;
    box-shadow: 0 4px 14px rgba(124, 109, 240, 0.4);
  }

  .btn-project-outline {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-project-outline:hover {
    background: var(--color-primary);
    color: #fff;
  }
</style>
