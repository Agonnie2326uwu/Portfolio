---
const projects = [
  {
    title: 'Hangarin',
    type: 'Web Application',
    desc: 'A full-featured web application built with modern technologies, demonstrating clean architecture and responsive design.',
    tags: ['SCSS', 'JavaScript', 'CSS', 'Python'],
    repo: 'https://github.com/Agonnie2326uwu/Hangarin',
    image: '',
  },
  {
    title: 'Palawan Endemic',
    type: 'Wildlife & Conservation',
    desc: 'A digital guide showcasing the unique endemic species of Palawan, Philippines. Features species profiles, habitat maps, and conservation resources.',
    tags: ['HTML', 'CSS', 'JavaScript', 'GitHub Pages'],
    repo: 'https://github.com/Agonnie2326uwu/Palawan-Endemic',
    image: '',
  },
];
---

<section class="section projects-section" id="projects">
  <div class="projects-inner">
      <h2 class="section-title">Projects</h2>
      <p class="section-subtitle">A selection of work I've built along my journey.</p>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <div class="project-card">
            {project.image && <div class="project-image"><img src={project.image} alt={project.title} /></div>}
            <div class="project-type">{project.type}</div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.desc}</p>
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {(project.repo || project.link) && (
              <div class="project-links">
                {project.repo && <a href={project.repo} target="_blank" rel="noopener noreferrer" class="btn-project">View on GitHub</a>}
                {project.link && <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-project btn-project-outline">Live Demo</a>}
              </div>
            )}
          </div>
        ))}
      </div>
  </div>
</section>

<style>
  .projects-section {
    position: relative;
    overflow: hidden;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 40px;
    border: var(--pixel-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.85);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .project-card:hover {
    border-color: var(--color-text);
    transform: translateY(-4px);
  }

  .project-image {
    width: calc(100% + 56px);
    margin: -28px -28px 20px;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    overflow: hidden;
    max-height: 180px;
  }

  .project-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .project-type {
    font-size: 0.78rem;
    color: var(--color-text-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .project-title {
    font-size: 1.4rem;
    margin-bottom: 12px;
    color: var(--color-text);
  }

  .project-desc {
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 0.72rem;
    padding: 4px 14px;
    border-radius: 20px;
    background: rgba(0, 0, 0, 0.05);
    color: var(--color-text);
    font-weight: 500;
    border: 1px solid rgba(0, 0, 0, 0.1);
    letter-spacing: 0.3px;
  }

  .project-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-card-border);
  }

  .btn-project {
    display: inline-block;
    padding: 8px 20px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    border: 2px solid var(--color-text);
    color: var(--color-text);
    transition: all 0.3s ease;
    letter-spacing: 0.3px;
    background: transparent;
  }

  .btn-project:hover {
    background: var(--color-text);
    color: var(--color-bg);
    transform: translateY(-1px);
  }

  .btn-project-outline {
    background: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-card-border);
  }

  .btn-project-outline:hover {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
    transform: translateY(-1px);
  }
</style>
