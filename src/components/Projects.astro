---
const projects = [
  {
    title: 'Hangarin',
    type: 'Web Application',
    desc: 'A full-featured web application built with modern technologies, demonstrating clean architecture and responsive design.',
    tags: ['SCSS', 'JavaScript', 'CSS', 'Python'],
    repo: 'https://github.com/Agonnie2326uwu/Hangarin',
    image: '',
  },
  {
    title: 'Palawan Endemic',
    type: 'Wildlife & Conservation',
    desc: 'A digital guide showcasing the unique endemic species of Palawan, Philippines. Features species profiles, habitat maps, and conservation resources.',
    tags: ['HTML', 'CSS', 'JavaScript', 'GitHub Pages'],
    repo: 'https://github.com/Agonnie2326uwu/Palawan-Endemic',
    image: '',
  },
];
---

<section class="section projects-section" id="projects">
  <div class="starwars-bg"></div>
  <div class="sw-ship tie-fighter">
    <svg viewBox="0 0 80 80" fill="none">
      <rect x="32" y="10" width="16" height="60" rx="2" fill="#333" stroke="#555" stroke-width="1"/>
      <rect x="10" y="32" width="60" height="16" rx="2" fill="#333" stroke="#555" stroke-width="1"/>
      <rect x="25" y="25" width="30" height="30" rx="1" fill="#2a2a2a" stroke="#444" stroke-width="1"/>
      <circle cx="40" cy="40" r="6" fill="#444" stroke="#666" stroke-width="1"/>
      <circle cx="40" cy="40" r="3" fill="#222"/>
      <rect x="5" y="36" width="8" height="8" fill="#2a2a2a" stroke="#444" stroke-width="0.5"/>
      <rect x="67" y="36" width="8" height="8" fill="#2a2a2a" stroke="#444" stroke-width="0.5"/>
      <rect x="36" y="8" width="8" height="8" fill="#2a2a2a" stroke="#444" stroke-width="0.5"/>
      <rect x="36" y="64" width="8" height="8" fill="#2a2a2a" stroke="#444" stroke-width="0.5"/>
      <rect x="30" y="14" width="4" height="52" fill="#2a2a2a"/>
      <rect x="46" y="14" width="4" height="52" fill="#2a2a2a"/>
      <rect x="14" y="30" width="52" height="4" fill="#2a2a2a"/>
      <rect x="14" y="46" width="52" height="4" fill="#2a2a2a"/>
    </svg>
  </div>
  <div class="projects-inner">
      <h2 class="section-title" data-animate>Projects</h2>
      <p class="section-subtitle" data-animate="fade">A selection of work I've built along my journey.</p>

      <div class="projects-grid">
        {projects.map((project, i) => (
          <div class="project-card float-anim" data-animate="scale" style={"transition-delay:" + (i * 0.15) + "s;animation-delay:" + (i * 0.8) + "s"}>
            {project.image && <div class="project-image"><img src={project.image} alt={project.title} /></div>}
            <div class="project-type">{project.type}</div>
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.desc}</p>
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {(project.repo || project.link) && (
              <div class="project-links">
                {project.repo && <a href={project.repo} target="_blank" rel="noopener noreferrer" class="btn-project">View on GitHub</a>}
                {project.link && <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn-project btn-project-outline">Live Demo</a>}
              </div>
            )}
          </div>
        ))}
      </div>
  </div>
</section>

<style>
  .projects-section {
    position: relative;
    overflow: hidden;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: 28px;
  }

  .project-image {
    width: calc(100% + 56px);
    margin: -28px -28px 20px;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    overflow: hidden;
    max-height: 180px;
  }

  .project-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .project-type {
    font-size: 0.78rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .project-title {
    font-size: 1.4rem;
    margin-bottom: 12px;
    color: #fff;
  }

  .project-desc {
    font-size: 0.92rem;
    line-height: 1.7;
    margin-bottom: 20px;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    font-size: 0.72rem;
    padding: 4px 14px;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(124, 109, 240, 0.15) 0%, rgba(74, 158, 255, 0.1) 100%);
    color: var(--color-text);
    font-weight: 500;
    border: 1px solid rgba(124, 109, 240, 0.1);
    letter-spacing: 0.3px;
  }

  .project-links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-card-border);
  }

  .btn-project {
    display: inline-block;
    padding: 8px 20px;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    background: var(--color-primary);
    color: #fff;
    transition: all 0.3s ease;
    letter-spacing: 0.3px;
  }

  .btn-project:hover {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: #fff;
    box-shadow: 0 4px 14px rgba(124, 109, 240, 0.4);
    transform: translateY(-1px);
  }

  .btn-project-outline {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid rgba(124, 109, 240, 0.3);
  }

  .btn-project-outline:hover {
    background: rgba(124, 109, 240, 0.1);
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-1px);
  }
</style>
