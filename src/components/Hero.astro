---
import Navigation from './Navigation.astro';
---

<Navigation />

<section class="hero" id="home">
  <div class="starwars-bg"></div>
  <div class="sw-ship death-star">
    <svg viewBox="0 0 160 160" fill="none">
      <circle cx="80" cy="80" r="70" fill="#2a2a2a" stroke="#555" stroke-width="2"/>
      <circle cx="80" cy="80" r="65" fill="#222" stroke="#444" stroke-width="1"/>
      <ellipse cx="65" cy="90" rx="18" ry="12" fill="#1a1a1a" stroke="#555" stroke-width="1.5"/>
      <rect x="58" y="84" width="14" height="3" rx="1" fill="#444"/>
      <rect x="55" y="90" width="20" height="2" rx="1" fill="#444"/>
      <rect x="60" y="78" width="10" height="2" rx="1" fill="#444"/>
      <circle cx="80" cy="60" r="3" fill="#555"/>
      <circle cx="95" cy="45" r="2" fill="#555"/>
      <circle cx="105" cy="70" r="2.5" fill="#555"/>
      <circle cx="60" cy="55" r="1.5" fill="#555"/>
      <circle cx="100" cy="100" r="2" fill="#555"/>
      <circle cx="50" cy="75" r="1.5" fill="#555"/>
      <line x1="80" y1="10" x2="80" y2="20" stroke="#666" stroke-width="1.5"/>
      <line x1="80" y1="140" x2="80" y2="150" stroke="#666" stroke-width="1.5"/>
      <line x1="10" y1="80" x2="20" y2="80" stroke="#666" stroke-width="1.5"/>
      <line x1="140" y1="80" x2="150" y2="80" stroke="#666" stroke-width="1.5"/>
    </svg>
  </div>
  <div class="sw-ship falcon">
    <svg viewBox="0 0 100 40" fill="none">
      <ellipse cx="50" cy="20" rx="30" ry="10" fill="#4a4a4a" stroke="#666" stroke-width="1.5"/>
      <rect x="20" y="14" width="20" height="12" rx="2" fill="#555" stroke="#777" stroke-width="1"/>
      <rect x="55" y="14" width="15" height="12" rx="2" fill="#555" stroke="#777" stroke-width="1"/>
      <rect x="40" y="10" width="10" height="4" fill="#3a3a3a" stroke="#666" stroke-width="1"/>
      <rect x="42" y="8" width="6" height="3" fill="#5a5a5a" stroke="#888" stroke-width="0.5"/>
      <rect x="65" y="17" width="18" height="6" rx="1" fill="#4a4a4a" stroke="#666" stroke-width="1"/>
      <rect x="17" y="17" width="8" height="6" rx="1" fill="#4a4a4a" stroke="#666" stroke-width="1"/>
      <circle cx="80" cy="20" r="3" fill="#6a6a6a" stroke="#888" stroke-width="0.5"/>
      <rect x="30" y="18" width="8" height="4" fill="#5a5a5a"/>
      <rect x="50" y="18" width="6" height="4" fill="#5a5a5a"/>
    </svg>
  </div>
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name hero-gradient">Carl De Castro</h1>
        <p class="hero-field">Web Developer &amp; Tech Support</p>
        <p class="hero-bio">A CS student from Puerto Princesa with a passion for web development and technology. Skilled in building responsive websites and providing reliable technical support. Committed to continuous learning and creating practical, user-focused digital solutions.</p>
        <div class="hero-actions">
          <a href="#projects" class="btn-text">View My Work</a>
          <a href="#contact" class="btn btn-outline">Get in Touch</a>
        </div>
      </div>
      <div class="hero-photo-wrapper" data-animate="scale">
        <div class="hero-photo-frame hover-zoom">
          <img src="/Me.png" alt="Carl Andre A. De Castro" class="hero-photo-img" />
        </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(124, 109, 240, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(74, 158, 255, 0.1) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 20%, rgba(240, 192, 64, 0.06) 0%, transparent 40%);
    z-index: 1;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    width: 100%;
  }

  .hero-photo-wrapper {
    flex-shrink: 0;
    position: relative;
  }

  .hero-photo-frame {
    width: 340px;
    height: 340px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(124, 109, 240, 0.2), 0 0 80px rgba(124, 109, 240, 0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .hero-photo-frame:hover {
    box-shadow: 0 0 60px rgba(124, 109, 240, 0.35), 0 0 120px rgba(124, 109, 240, 0.12);
    transform: scale(1.02);
  }

  .hero-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-text {
    text-align: left;
    flex: 1;
  }

  .hero-greeting {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-secondary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    animation: fadeInUp 0.6s ease 0.2s both;
    font-weight: 500;
    opacity: 0.8;
  }

  .hero-name {
    font-size: 3.2rem;
    color: var(--color-primary);
    margin-bottom: 12px;
    text-shadow: 0 0 15px rgba(57, 255, 20, 0.4);
    animation: fadeInUp 0.6s ease 0.3s both;
    letter-spacing: 2px;
    line-height: 1.2;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .hero-gradient {
    background: none;
    -webkit-text-fill-color: var(--color-primary);
    color: var(--color-primary);
  }

  .hero-field {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 16px;
    font-weight: 400;
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.3);
    animation: fadeInUp 0.6s ease 0.4s both;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
    padding-bottom: 14px;
  }

  .hero-field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(0, 240, 255, 0.5);
    opacity: 0.7;
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.8;
    max-width: 460px;
    margin-bottom: 28px;
    animation: fadeInUp 0.6s ease 0.5s both;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease 0.6s both;
  }

  .hero-actions .btn-outline {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero-actions .btn-outline:hover {
    background: rgba(0, 240, 255, 0.1);
    color: var(--color-accent);
  }

  .btn-text {
    display: inline-block;
    padding: 14px 32px;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.3s ease;
    image-rendering: pixelated;
    border: var(--pixel-border);
  }

  .btn-text:hover {
    color: var(--color-primary-dark);
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero-card {
      padding: 32px 24px 28px;
    }

    .hero-content {
      flex-direction: column-reverse;
      gap: 24px;
    }

    .hero-text {
      text-align: center;
    }

    .hero-field::after {
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-bio {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-name {
      font-size: 2.2rem;
    }

    .hero-field {
      font-size: 1rem;
    }

    .hero-photo-frame {
      width: 180px;
      height: 180px;
    }

    .hero-bio {
      font-size: 0.92rem;
    }
  }
</style>
