---
import Navigation from './Navigation.astro';
---

<Navigation />

<section class="hero" id="home">
  <div class="planet planet-saturn" style="top:18%;left:6%;"></div>
  <div class="planet planet-nebula" style="bottom:28%;left:3%;transform:scale(0.8);"></div>
  <div class="planet planet-small" style="bottom:15%;right:5%;"></div>
  <div class="planet planet-small" style="top:40%;right:2%;"></div>
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name hero-gradient">Carl De Castro</h1>
        <p class="hero-field">Web Developer &amp; Tech Support</p>
        <p class="hero-bio">A CS student from Puerto Princesa who enjoys building software, solving problems, and caring for animals. I'm always learning and working on projects I can be proud of.</p>
        <div class="hero-actions">
          <a href="#projects" class="btn-text">View My Work</a>
          <a href="#contact" class="btn btn-outline">Get in Touch</a>
        </div>
      </div>
      <div class="hero-photo-wrapper" data-animate="scale">
        <div class="hero-photo-frame hover-zoom">
          <img src="/Me.png" alt="Carl Andre A. De Castro" class="hero-photo-img" />
        </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(124, 109, 240, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(74, 158, 255, 0.1) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 20%, rgba(240, 192, 64, 0.06) 0%, transparent 40%);
    z-index: 1;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
    width: 100%;
  }

  .hero-photo-wrapper {
    flex-shrink: 0;
    position: relative;
  }

  .hero-photo-frame {
    width: 340px;
    height: 340px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(124, 109, 240, 0.2), 0 0 80px rgba(124, 109, 240, 0.08);
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .hero-photo-frame:hover {
    box-shadow: 0 0 60px rgba(124, 109, 240, 0.35), 0 0 120px rgba(124, 109, 240, 0.12);
    transform: scale(1.02);
  }

  .hero-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-text {
    text-align: left;
    flex: 1;
  }

  .hero-greeting {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-secondary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    animation: fadeInUp 0.6s ease 0.2s both;
    font-weight: 500;
    opacity: 0.8;
  }

  .hero-name {
    font-size: 3.2rem;
    color: var(--color-primary);
    margin-bottom: 12px;
    text-shadow: 0 0 15px rgba(57, 255, 20, 0.4);
    animation: fadeInUp 0.6s ease 0.3s both;
    letter-spacing: 2px;
    line-height: 1.2;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .hero-gradient {
    background: none;
    -webkit-text-fill-color: var(--color-primary);
    color: var(--color-primary);
  }

  .hero-field {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 16px;
    font-weight: 400;
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.3);
    animation: fadeInUp 0.6s ease 0.4s both;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
    padding-bottom: 14px;
  }

  .hero-field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-accent);
    box-shadow: 0 0 6px rgba(0, 240, 255, 0.5);
    opacity: 0.7;
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.8;
    max-width: 460px;
    margin-bottom: 28px;
    animation: fadeInUp 0.6s ease 0.5s both;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease 0.6s both;
  }

  .hero-actions .btn-outline {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .hero-actions .btn-outline:hover {
    background: rgba(0, 240, 255, 0.1);
    color: var(--color-accent);
  }

  .btn-text {
    display: inline-block;
    padding: 14px 32px;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.3s ease;
    image-rendering: pixelated;
  }

  .btn-text:hover {
    color: var(--color-primary-dark);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero-card {
      padding: 32px 24px 28px;
    }

    .hero-content {
      flex-direction: column-reverse;
      gap: 24px;
    }

    .hero-text {
      text-align: center;
    }

    .hero-field::after {
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-bio {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-name {
      font-size: 2.2rem;
    }

    .hero-field {
      font-size: 1rem;
    }

    .hero-photo-frame {
      width: 180px;
      height: 180px;
    }

    .hero-bio {
      font-size: 0.92rem;
    }
  }
</style>
