---
import Navigation from './Navigation.astro';
---

<Navigation />

<section class="hero" id="home">
  <div class="cosmic-bg" data-parallax="0.15"></div>
  <div class="stars-dense" data-parallax="0.1"></div>
  <div class="stars-dense" style="transform: scale(1.5) rotate(45deg); opacity: 0.5;"></div>
  <div class="hero-nebula"></div>
  <div class="moon-big moon-top-right"></div>
  <div class="planet planet-saturn" style="top:18%;left:6%;"></div>
  <div class="planet planet-nebula" style="bottom:28%;left:3%;transform:scale(0.8);"></div>
  <div class="planet planet-small" style="bottom:15%;right:5%;"></div>
  <div class="planet planet-small" style="top:40%;right:2%;"></div>
  <div class="constellation constellation-1">
    <svg viewBox="0 0 120 80">
      <circle class="constellation-dot" cx="10" cy="20" r="3" />
      <circle class="constellation-dot" cx="30" cy="55" r="2.5" />
      <circle class="constellation-dot" cx="60" cy="15" r="3" />
      <circle class="constellation-dot" cx="90" cy="45" r="2.5" />
      <circle class="constellation-dot" cx="110" cy="25" r="2" />
      <line class="constellation-line" x1="10" y1="20" x2="30" y2="55" />
      <line class="constellation-line" x1="30" y1="55" x2="60" y2="15" />
      <line class="constellation-line" x1="60" y1="15" x2="90" y2="45" />
      <line class="constellation-line constellation-line-2" x1="90" y1="45" x2="110" y2="25" />
    </svg>
  </div>
  <div class="constellation constellation-2" style="top:auto;bottom:10%;right:2%;width:90px;height:60px;">
    <svg viewBox="0 0 90 60">
      <circle class="constellation-dot" cx="10" cy="40" r="2" />
      <circle class="constellation-dot" cx="25" cy="10" r="2.5" />
      <circle class="constellation-dot" cx="45" cy="30" r="2" />
      <circle class="constellation-dot" cx="65" cy="8" r="2" />
      <circle class="constellation-dot" cx="82" cy="45" r="2" />
      <line class="constellation-line" x1="10" y1="40" x2="25" y2="10" />
      <line class="constellation-line" x1="25" y1="10" x2="45" y2="30" />
      <line class="constellation-line" x1="45" y1="30" x2="65" y2="8" />
      <line class="constellation-line constellation-line-2" x1="65" y1="8" x2="82" y2="45" />
    </svg>
  </div>
  <div class="constellation constellation-3" style="top:auto;bottom:30%;left:2%;width:80px;height:55px;">
    <svg viewBox="0 0 80 55">
      <circle class="constellation-dot" cx="15" cy="40" r="2.5" />
      <circle class="constellation-dot" cx="35" cy="15" r="2" />
      <circle class="constellation-dot" cx="55" cy="30" r="2.5" />
      <circle class="constellation-dot" cx="70" cy="8" r="2" />
      <line class="constellation-line" x1="15" y1="40" x2="35" y2="15" />
      <line class="constellation-line" x1="35" y1="15" x2="55" y2="30" />
      <line class="constellation-line" x1="55" y1="30" x2="70" y2="8" />
    </svg>
  </div>
  <div class="star star-1"></div>
  <div class="star star-2"></div>
  <div class="star star-3"></div>
  <div class="star star-4"></div>
  <div class="star star-5"></div>
  <div class="star star-6"></div>
  <div class="star star-7"></div>
  <div class="star star-8"></div>
  <div class="star star-9"></div>
  <div class="star star-10"></div>
  <div class="shooting-star shooting-star-1"></div>
  <div class="shooting-star shooting-star-2"></div>
  <div class="shooting-star" style="top:30%;right:60%;animation: shootStar 14s ease-in-out 4s infinite;width:2px;height:2px;"></div>
  <div class="shooting-star" style="top:5%;right:30%;animation: shootStar 10s ease-in-out 8s infinite;"></div>
  <div class="hero-content">
    <p class="hero-greeting">Hello, I'm</p>
    <h1 class="hero-name hero-gradient">Carl De Castro</h1>
    <p class="hero-role">Computer Science Student &amp; Software Developer</p>
    <p class="hero-tagline"><span class="typing-text"></span><span class="typing-cursor">|</span></p>
    <div class="hero-info">
      <div class="hero-info-item">
        <span class="hero-info-label">Age</span>
        <span class="hero-info-value">23</span>
      </div>
      <div class="hero-info-item">
        <span class="hero-info-label">Locale</span>
        <span class="hero-info-value">Puerto Princesa</span>
      </div>
      <div class="hero-info-item">
        <span class="hero-info-label">Status</span>
        <span class="hero-info-value">CS Student</span>
      </div>
    </div>
    <div class="hero-actions">
      <a href="#projects" class="btn btn-primary">View My Work</a>
      <a href="#contact" class="btn btn-outline">Get in Touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-nebula {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(124, 109, 240, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, rgba(74, 158, 255, 0.1) 0%, transparent 40%),
      radial-gradient(ellipse at 50% 20%, rgba(240, 192, 64, 0.06) 0%, transparent 40%);
    z-index: 1;
  }

  .hero-content {
    text-align: center;
    z-index: 2;
    max-width: 700px;
  }

  .hero-greeting {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-secondary);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 8px;
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .hero-name {
    font-size: 3.6rem;
    color: #fff;
    margin-bottom: 8px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6);
    animation: fadeInUp 0.6s ease 0.3s both;
    letter-spacing: -1px;
  }

  .hero-gradient {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 40%, var(--color-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .typing-cursor {
    animation: blink 0.8s step-end infinite;
    color: var(--color-primary);
    font-weight: 100;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-role {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 12px;
    font-weight: 400;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    animation: fadeInUp 0.6s ease 0.4s both;
  }

  .hero-tagline {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: 24px;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    animation: fadeInUp 0.6s ease 0.5s both;
  }

  .hero-info {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
    animation: fadeInUp 0.6s ease 0.55s both;
  }

  .hero-info-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .hero-info-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-text-light);
    opacity: 0.7;
  }

  .hero-info-value {
    font-size: 0.95rem;
    color: #fff;
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease 0.6s both;
  }

  .hero-actions .btn-outline {
    color: #fff;
    border-color: #fff;
    border-width: 2px;
  }

  .hero-actions .btn-outline:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  @media (max-width: 640px) {
    .hero-name {
      font-size: 2.2rem;
    }
    .hero-role {
      font-size: 1rem;
    }
  }
</style>

<script>
  const texts = [
    "Exploring code, solving problems, and building things that matter.",
    "Learning and growing every single day.",
  ];
  let textIndex = 0;
  let charIndex = 0;
  const el = document.querySelector('.typing-text');

  function type() {
    if (charIndex < texts[textIndex].length) {
      el.textContent += texts[textIndex][charIndex];
      charIndex++;
      setTimeout(type, 40 + Math.random() * 30);
    } else {
      setTimeout(erase, 2500);
    }
  }

  function erase() {
    if (charIndex > 0) {
      el.textContent = texts[textIndex].slice(0, charIndex - 1);
      charIndex--;
      setTimeout(erase, 20);
    } else {
      textIndex = (textIndex + 1) % texts.length;
      setTimeout(type, 500);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(type, 1200);
  });
</script>
