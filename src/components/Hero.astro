---
import Navigation from './Navigation.astro';
---

<Navigation />

<section class="hero pattern-stripes" id="home">
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name">Carl De Castro</h1>
        <p class="hero-field">Web Developer &amp; Tech Support</p>
        <p class="hero-bio">CS student from Puerto Princesa — I build responsive websites, solve tech problems, and turn ideas into practical digital solutions. Always learning, always building.</p>
        <div class="hero-actions">
          <a href="#projects" class="btn-text">View My Work</a>
          <a href="#contact" class="btn btn-outline">Get in Touch</a>
        </div>
      </div>
      <div class="hero-photo-wrapper">
        <div class="hero-photo-frame hover-zoom">
          <img src="/Me.png" alt="Carl Andre A. De Castro" class="hero-photo-img" />
        </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 64px;
    width: 100%;
    padding: 64px 80px;
    background: rgba(255, 255, 255, 0.4);
    border: var(--pixel-border);
    border-radius: var(--radius-lg);
    position: relative;
    z-index: 1;
  }

  .hero-photo-wrapper {
    flex-shrink: 0;
    position: relative;
  }

  .hero-photo-frame {
    width: 480px;
    height: 480px;
    border-radius: 16px;
    overflow: hidden;
    border: var(--pixel-border);
    transition: transform 0.3s ease;
  }

  .hero-photo-frame:hover {
    transform: scale(1.02);
  }

  .hero-photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-text {
    text-align: left;
    flex: 1;
  }

  .hero-greeting {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-light);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
    font-weight: 500;
  }

  .hero-name {
    font-size: 4.5rem;
    color: var(--color-text);
    margin-bottom: 12px;
    letter-spacing: 2px;
    line-height: 1.2;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .hero-field {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: 16px;
    font-weight: 400;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
    padding-bottom: 14px;
  }

  .hero-field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-text-light);
    opacity: 0.5;
  }

  .hero-bio {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.8;
    max-width: 460px;
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .btn-text {
    display: inline-block;
    padding: 14px 32px;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: var(--pixel-border);
  }

  .btn-text:hover {
    border-color: var(--color-text);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      gap: 24px;
    }

    .hero-text {
      text-align: center;
    }

    .hero-field::after {
      left: 50%;
      transform: translateX(-50%);
    }

    .hero-bio {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-name {
      font-size: 2.6rem;
    }

    .hero-field {
      font-size: 1rem;
    }

    .hero-photo-frame {
      width: 280px;
      height: 280px;
    }

    .hero-bio {
      font-size: 0.92rem;
    }
  }
</style>
