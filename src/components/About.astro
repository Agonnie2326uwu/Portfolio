---

<section class="section about-section" id="about">
  <div class="about-inner">
      <h2 class="section-title">About Me</h2>
      <p class="section-subtitle">A glimpse into who I am and what drives me.</p>

      <div class="about-layout">
        <div class="about-card card">
          <div class="about-text">
            <p>
              CS student with experience in Java, Python, C++, and C# across academic and personal projects.
              Focused on writing clean code, solving problems efficiently.
              Outside of technology, I'm into helping stray animals and collecting cards.
            </p>
          </div>
        </div>

        <div class="personal-info card">
          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">Name</span>
              <span class="info-value">Carl De Castro</span>
            </div>
            <div class="info-item">
              <span class="info-label">Age</span>
              <span class="info-value">23</span>
            </div>
            <div class="info-item">
              <span class="info-label">Locale</span>
              <span class="info-value">Puerto Princesa</span>
            </div>
            <div class="info-item">
              <span class="info-label">Status</span>
              <span class="info-value">CS Student</span>
            </div>
          </div>
      </div>
      <div class="info-image">
        <img src="/balls.png" alt="Decorative illustration" />
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: hidden;
  }

  .about-card {
    padding: 24px;
  }


  .about-text p {
    margin-bottom: 0;
    font-size: 1rem;
    line-height: 1.7;
    text-align: justify;
  }

  .personal-info {
    padding: 24px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 14px 10px;
    background: rgba(0, 0, 0, 0.03);
    text-align: center;
    border: var(--pixel-border);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .info-item:hover {
    border-color: var(--color-text);
    background: rgba(0, 0, 0, 0.06);
  }

  .info-label {
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .info-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .info-image {
    margin-top: -48px;
    display: flex;
    justify-content: center;
    width: 100%;
    position: relative;
    z-index: 2;
    padding-left: 72px;
  }

  .info-image img {
    width: 400px;
    height: auto;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .about-card {
      padding: 28px 20px;
    }

    .about-text p {
      font-size: 0.95rem;
    }
  }
</style>
