---
---

<section class="section about-section" id="about">
  <div class="cosmic-bg" data-parallax="0.15"></div>
  <div class="stars-dense" data-parallax="0.1"></div>
  <div class="cosmic-overlay"></div>
  <div class="moon-big moon-mid-right"></div>
  <div class="planet planet-saturn" style="top:45%;left:5%;transform:scale(0.8);"></div>
  <div class="constellation constellation-2">
    <svg viewBox="0 0 100 70">
      <circle class="constellation-dot" cx="15" cy="50" r="2.5" />
      <circle class="constellation-dot" cx="35" cy="15" r="3" />
      <circle class="constellation-dot" cx="60" cy="35" r="2.5" />
      <circle class="constellation-dot" cx="85" cy="55" r="2" />
      <line class="constellation-line" x1="15" y1="50" x2="35" y2="15" />
      <line class="constellation-line" x1="35" y1="15" x2="60" y2="35" />
      <line class="constellation-line constellation-line-2" x1="60" y1="35" x2="85" y2="55" />
    </svg>
  </div>
  <div class="constellation constellation-1">
    <svg viewBox="0 0 120 80">
      <circle class="constellation-dot" cx="10" cy="20" r="2" />
      <circle class="constellation-dot" cx="30" cy="55" r="2" />
      <circle class="constellation-dot" cx="60" cy="15" r="2.5" />
      <circle class="constellation-dot" cx="90" cy="45" r="2" />
      <line class="constellation-line" x1="10" y1="20" x2="30" y2="55" />
      <line class="constellation-line" x1="30" y1="55" x2="60" y2="15" />
      <line class="constellation-line" x1="60" y1="15" x2="90" y2="45" />
    </svg>
  </div>
  <div class="particle" style="bottom:20%;left:10%;--dur:18s;--delay:0s;--drift:15px;"></div>
  <div class="particle" style="bottom:40%;left:30%;--dur:22s;--delay:3s;--drift:-20px;--opacity:0.3;"></div>
  <div class="particle" style="bottom:60%;left:55%;--dur:16s;--delay:6s;--drift:10px;"></div>
  <div class="particle" style="bottom:30%;left:75%;--dur:20s;--delay:2s;--drift:-15px;--opacity:0.25;"></div>
  <div class="particle" style="bottom:70%;left:85%;--dur:14s;--delay:5s;--drift:25px;"></div>
  <div class="shooting-star" style="top:15%;right:30%;animation:shootStar 12s ease-in-out 3s infinite;width:2px;height:2px;"></div>
  <div class="shooting-star" style="top:50%;right:10%;animation:shootStar 16s ease-in-out 8s infinite;"></div>
  <div class="star star-1"></div>
  <div class="star star-3"></div>
  <div class="star star-5"></div>
  <div class="star star-7"></div>
  <div class="star star-9"></div>
  <div class="star star-6"></div>
  <div class="star star-10"></div>
  <div class="about-inner cosmic-inner">
    <h2 class="section-title" data-animate>About Me</h2>
    <p class="section-subtitle" data-animate="fade">A Computer Science student with a passion for building and learning.</p>

    <div class="about-layout">
      <div class="about-card card" data-animate="left">
        <div class="about-photo">
          <div class="photo-frame">
            <img src="/me.png" alt="Carl De Castro" class="photo-img" />
          </div>
        </div>
        <div class="about-text">
          <p>
            Hi! I'm Carl De Castro, a 23-year-old Computer Science student who enjoys learning about software
            development and finding practical solutions through programming. Over the years, I've worked with
            Java, Python, C++, and C# on different academic and personal projects, which helped me strengthen
            my programming and problem-solving skills.
          </p>
          <p>
            I like taking on new challenges because they give me the opportunity to improve and learn something
            new. Outside of coding, I enjoy spending time with animals and learning more about wildlife. I'm
            currently focused on building my experience as a developer while continuing to improve my technical
            knowledge and create projects that I can be proud of.
          </p>
        </div>
      </div>

      <div class="personal-info card" data-animate="right">
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Name</span>
            <span class="info-value">Carl De Castro</span>
          </div>
          <div class="info-item">
            <span class="info-label">Age</span>
            <span class="info-value">23</span>
          </div>
          <div class="info-item">
            <span class="info-label">Locale</span>
            <span class="info-value">Puerto Princesa</span>
          </div>
          <div class="info-item">
            <span class="info-label">Status</span>
            <span class="info-value">CS Student</span>
          </div>
        </div>
      </div>

      <div class="learning-card card" data-animate="fade">
        <div class="learning-content">
          <span class="learning-badge">Currently Learning</span>
          <div class="learning-detail">
            <span class="learning-lang">日本語</span>
            <span class="learning-label">Japanese Language</span>
          </div>
          <div class="learning-progress">
            <div class="learning-bar" style="width:25%"></div>
          </div>
          <p class="learning-note">Building vocabulary and practicing conversation skills.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    overflow: hidden;
  }

  .about-card {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    padding: 40px;
  }

  .about-photo {
    flex-shrink: 0;
    margin-top: 12px;
  }

  .photo-frame {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    border: 3px solid rgba(124, 109, 240, 0.3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(124, 109, 240, 0.1);
    box-shadow: 0 0 30px rgba(124, 109, 240, 0.15), 0 0 60px rgba(124, 109, 240, 0.05);
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .photo-frame:hover {
    box-shadow: 0 0 40px rgba(124, 109, 240, 0.3), 0 0 80px rgba(124, 109, 240, 0.1);
    border-color: rgba(124, 109, 240, 0.5);
  }

  .photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .photo-img:hover {
    transform: scale(1.05);
  }

  .about-text p {
    margin-bottom: 16px;
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .personal-info {
    padding: 28px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 20px 12px;
    border-radius: var(--radius-sm);
    background: rgba(6, 10, 26, 0.5);
    text-align: center;
    border: 1px solid rgba(124, 109, 240, 0.08);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .info-item:hover {
    border-color: rgba(124, 109, 240, 0.2);
    background: rgba(6, 10, 26, 0.7);
  }

  .info-label {
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-family: var(--font-heading);
    font-weight: 600;
  }

  .info-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .learning-card {
    padding: 24px 32px;
  }

  .learning-content {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .learning-badge {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-secondary);
    background: linear-gradient(135deg, rgba(240, 192, 64, 0.12) 0%, rgba(240, 192, 64, 0.05) 100%);
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid rgba(240, 192, 64, 0.2);
    box-shadow: 0 0 20px rgba(240, 192, 64, 0.05);
  }

  .learning-detail {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .learning-lang {
    font-size: 1.3rem;
    font-weight: 700;
    font-family: var(--font-heading);
    color: #fff;
    letter-spacing: 1px;
  }

  .learning-label {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .learning-progress {
    flex: 1;
    min-width: 120px;
    height: 6px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .learning-bar {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    transition: width 0.6s ease;
  }

  .learning-note {
    font-size: 0.82rem;
    color: var(--color-text-light);
    width: 100%;
  }

  @media (max-width: 640px) {
    .about-card {
      flex-direction: column;
      text-align: center;
      padding: 28px 20px;
      align-items: center;
    }
    .about-photo {
      margin-top: 0;
    }
    .photo-frame {
      width: 120px;
      height: 120px;
    }

    .learning-content {
      flex-direction: column;
      text-align: center;
    }

    .learning-progress {
      width: 100%;
    }
  }
</style>
